<mujoco model="turtlebot3_waffle_pi">
  <compiler angle="radian" meshdir="assets/"/>

  <option cone="elliptic" impratio="10"/>

  <asset>
    <material name="grey" rgba="0.3 0.3 0.3 1"/>
    <material name="black" rgba="0.1 0.1 0.1 1"/>

    <mesh name="waffle_pi_base" file="waffle_pi_base.stl" scale="0.001 0.001 0.001"/>
    <mesh name="left_tire" file="left_tire.stl" scale="0.001 0.001 0.001"/>
    <mesh name="right_tire" file="right_tire.stl" scale="0.001 0.001 0.001"/>
    <mesh name="lds" file="lds.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <default>
    <!-- Wheel motor -->
    <default class="wheel">
      <joint limited="false" frictionloss="0.1" armature="0.01"/>
      <velocity kv="5.0" ctrlrange="-7.88 7.88" ctrllimited="true"/>
      <default class="wheel_left">
        <joint axis="0 0 1"/>
      </default>
      <default class="wheel_right">
        <joint axis="0 0 1"/>
      </default>
    </default>
    <!-- Visual / Collision -->
    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" density="0" group="2"/>
    </default>
    <default class="collision">
      <geom group="3" type="mesh"/>
    </default>
  </default>

  <worldbody>
    <body name="base" pos="0 0 0">
      <inertial pos="-0.064 0 0.06" mass="1.8" diaginertia="0.01 0.01 0.008"/>
      <joint type="free" name="base_joint"/>
      <geom pos="-0.064 0 0.01" mesh="waffle_pi_base" material="black" class="visual"/>
      <geom pos="-0.064 0 0.01" mesh="waffle_pi_base" class="collision"/>
      <geom size="0.005" pos="-0.177 -0.064 0.005" type="sphere" material="grey" friction="0.0001 0.0001 0.0001" solref="0.02 1" solimp="0.95 0.99 0.001" condim="1"/>
      <geom size="0.005" pos="-0.177 0.064 0.005" type="sphere" material="grey" friction="0.0001 0.0001 0.0001" solref="0.02 1" solimp="0.95 0.99 0.001" condim="1"/>
      <geom pos="-0.049 0 0.1255" mesh="lds" material="black" class="visual"/>
      <geom pos="-0.049 0 0.1255" mesh="lds" class="collision"/>
      <geom size="0.0075 0.015 0.0135" pos="0.078 0 0.107" type="box" material="grey"/>
      <body name="imu_link" pos="0 0 0.068">
        <site name="imu_site" size="0.003" rgba="0 0.8 0 0.6"/>
      </body>
      <body name="base_scan" pos="-0.064 0 0.122">
        <site name="scan_site_0" size="0.002" zaxis="-1.000000 0.000000 0"/>
        <site name="scan_site_1" size="0.002" zaxis="-0.939693 -0.342020 0"/>
        <site name="scan_site_2" size="0.002" zaxis="-0.766044 -0.642788 0"/>
        <site name="scan_site_3" size="0.002" zaxis="-0.500000 -0.866025 0"/>
        <site name="scan_site_4" size="0.002" zaxis="-0.173648 -0.984808 0"/>
        <site name="scan_site_5" size="0.002" zaxis="0.173648 -0.984808 0"/>
        <site name="scan_site_6" size="0.002" zaxis="0.500000 -0.866025 0"/>
        <site name="scan_site_7" size="0.002" zaxis="0.766044 -0.642788 0"/>
        <site name="scan_site_8" size="0.002" zaxis="0.939693 -0.342020 0"/>
        <site name="scan_site_9" size="0.002" zaxis="1.000000 0.000000 0"/>
        <site name="scan_site_10" size="0.002" zaxis="0.939693 0.342020 0"/>
        <site name="scan_site_11" size="0.002" zaxis="0.766044 0.642788 0"/>
        <site name="scan_site_12" size="0.002" zaxis="0.500000 0.866025 0"/>
        <site name="scan_site_13" size="0.002" zaxis="0.173648 0.984808 0"/>
        <site name="scan_site_14" size="0.002" zaxis="-0.173648 0.984808 0"/>
        <site name="scan_site_15" size="0.002" zaxis="-0.500000 0.866025 0"/>
        <site name="scan_site_16" size="0.002" zaxis="-0.766044 0.642788 0"/>
        <site name="scan_site_17" size="0.002" zaxis="-0.939693 0.342020 0"/>
        <site name="scan_site_18" size="0.002" zaxis="-1.000000 0.000000 0"/>
      </body>
      <body name="camera_link" pos="0.073 -0.011 0.084">
        <body name="camera_rgb_frame" pos="0.003 0.011 0.009">
          <camera name="front_camera" pos="0 0 0" xyaxes="0 -1 0 0 0 1" fovy="60"/>
        </body>
      </body>
      <body name="wheel_left" pos="0 0.144 0.033" quat="0.707388 -0.706825 0 0">
        <inertial pos="0 0 0" quat="-0.000890159 0.706886 0.000889646 0.707326" mass="0.0284989" diaginertia="2.07126e-05 1.11924e-05 1.11756e-05"/>
        <joint name="wheel_left" class="wheel_left"/>
        <geom quat="0.707388 0.706825 0 0" mesh="left_tire" material="grey" class="visual"/>
        <geom type="cylinder" size="0.033 0.009" friction="1.5 0.02 0.001" condim="6"/>
      </body>
      <body name="wheel_right" pos="0 -0.144 0.033" quat="0.707388 -0.706825 0 0">
        <inertial pos="0 0 0" quat="-0.000890159 0.706886 0.000889646 0.707326" mass="0.0284989" diaginertia="2.07126e-05 1.11924e-05 1.11756e-05"/>
        <joint name="wheel_right" class="wheel_right"/>
        <geom quat="0.707388 0.706825 0 0" mesh="right_tire" material="grey" class="visual"/>
        <geom type="cylinder" size="0.033 0.009" friction="1.5 0.02 0.001" condim="6"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity class="wheel_left" name="wheel_left" joint="wheel_left"/>
    <velocity class="wheel_right" name="wheel_right" joint="wheel_right"/>
  </actuator>

  <sensor>
    <framequat name="tb3_imu_quat" objtype="site" objname="imu_site"/>
    <gyro name="tb3_imu_gyro" site="imu_site"/>
    <accelerometer name="tb3_imu_accel" site="imu_site"/>
    <rangefinder name="scan_beam-0" site="scan_site_0"/>
    <rangefinder name="scan_beam-1" site="scan_site_1"/>
    <rangefinder name="scan_beam-2" site="scan_site_2"/>
    <rangefinder name="scan_beam-3" site="scan_site_3"/>
    <rangefinder name="scan_beam-4" site="scan_site_4"/>
    <rangefinder name="scan_beam-5" site="scan_site_5"/>
    <rangefinder name="scan_beam-6" site="scan_site_6"/>
    <rangefinder name="scan_beam-7" site="scan_site_7"/>
    <rangefinder name="scan_beam-8" site="scan_site_8"/>
    <rangefinder name="scan_beam-9" site="scan_site_9"/>
    <rangefinder name="scan_beam-10" site="scan_site_10"/>
    <rangefinder name="scan_beam-11" site="scan_site_11"/>
    <rangefinder name="scan_beam-12" site="scan_site_12"/>
    <rangefinder name="scan_beam-13" site="scan_site_13"/>
    <rangefinder name="scan_beam-14" site="scan_site_14"/>
    <rangefinder name="scan_beam-15" site="scan_site_15"/>
    <rangefinder name="scan_beam-16" site="scan_site_16"/>
    <rangefinder name="scan_beam-17" site="scan_site_17"/>
    <rangefinder name="scan_beam-18" site="scan_site_18"/>
  </sensor>

  <keyframe>
    <key name="home" qpos="0 0 0 1 0 0 0 0 0" ctrl="0 0"/>
  </keyframe>

  <contact>
    <exclude body1="base" body2="wheel_left"/>
    <exclude body1="base" body2="wheel_right"/>
  </contact>
</mujoco>
